# ====================================
# VARIABLES DE ENTORNO - BACKEND
# ====================================
# Copia este archivo a .env y completa los valores reales
# NUNCA comitees el archivo .env con datos sensibles

# BASE DE DATOS
# Reemplaza con tus credenciales de PostgreSQL
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/sistemamine?schema=public"

# SEGURIDAD JWT
# En producción, usa una cadena larga y aleatoria (min 32 caracteres)
JWT_SECRET="tu_clave_jwt_super_secreta_aqui"

# CONFIGURACIÓN DE PUERTO
# Puerto en el que corre el servidor (default: 3000)
PORT=3000

# ====================================
# CONFIGURACIÓN DE CORREOS
# ====================================
# Gmail u otro proveedor SMTP
# Para Gmail, usa contraseña de aplicación (no la de tu cuenta)
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion

# Correos donde llegarán notificaciones
EMAIL_GERENCIA=gerencia@tu_empresa.com
EMAIL_JEFE_PLANTA=jefe.planta@tu_empresa.com

# ====================================
# CONFIGURACIÓN DE FRONTEND (opcional)
# ====================================
# URL del servidor backend
VITE_API_URL=http://localhost:3000
